  status         WmsTransferStatus @default(COMPLETED)
  notes          String?
  createdById    String?           @db.Uuid
  createdBy      User?             @relation("WmsTransferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById    String?           @db.Uuid
  updatedBy      User?             @relation("WmsTransferUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          WmsTransferItem[]

  @@index([tenantId, warehouseId, createdAt])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("wms_transfers")
}

model WmsTransferItem {
  id              String           @id @default(uuid()) @db.Uuid
  transferId      String           @db.Uuid
  transfer        WmsTransfer      @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryUnitId String           @db.Uuid
  inventoryUnit   WmsInventoryUnit @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  lineNo          Int
  createdAt       DateTime         @default(now())

  @@unique([transferId, lineNo])
  @@unique([transferId, inventoryUnitId])
  @@index([inventoryUnitId])
  @@map("wms_transfer_items")
}

model WmsInventoryMovement {
  id              String                   @id @default(uuid()) @db.Uuid
  tenantId        String                   @db.Uuid
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId          String?                  @db.Uuid
  team            Team?                    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  inventoryUnitId String                   @db.Uuid
  inventoryUnit   WmsInventoryUnit         @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  warehouseId     String                   @db.Uuid
  warehouse       WmsWarehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  fromLocationId  String?                  @db.Uuid
  fromLocation    WmsLocation?             @relation("WmsInventoryMovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocationId    String?                  @db.Uuid
  toLocation      WmsLocation?             @relation("WmsInventoryMovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  fromStatus      WmsInventoryUnitStatus?
  toStatus        WmsInventoryUnitStatus?
  movementType    WmsInventoryMovementType
  referenceType   String?
  referenceId     String?
  referenceCode   String?
  notes           String?
  actorId         String?                  @db.Uuid
  actor           User?                    @relation("WmsInventoryMovementActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now())

  @@index([tenantId, warehouseId, createdAt])
  @@index([inventoryUnitId, createdAt])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([referenceType, referenceId])
  @@index([actorId])
  @@map("wms_inventory_movements")
}

model WmsLabelPrintLog {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId          String?            @db.Uuid
  actor            User?              @relation("WmsLabelPrintLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  scope            String
  action           String
  receivingBatchId String?            @db.Uuid
  receivingBatch   WmsReceivingBatch? @relation("WmsLabelPrintLogBatch", fields: [receivingBatchId], references: [id], onDelete: SetNull)
  inventoryUnitId  String?            @db.Uuid
  inventoryUnit    WmsInventoryUnit?  @relation("WmsLabelPrintLogUnit", fields: [inventoryUnitId], references: [id], onDelete: SetNull)
  itemCount        Int                @default(1)
  metadata         Json?
  createdAt        DateTime           @default(now())

  @@index([tenantId, createdAt])
  @@index([scope, createdAt])
  @@index([receivingBatchId])
  @@index([inventoryUnitId])
  @@index([actorId])
  @@map("wms_label_print_logs")
}

model PosProvince {
  id          String        @id
  countryCode Int
  name        String
  nameEn      String?
  newId       String?
  regionType  String?
  districts   PosDistrict[]
  communes    PosCommune[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([countryCode, name])
  @@map("pos_provinces")
}

model PosDistrict {
  id         String       @id
  provinceId String
  province   PosProvince  @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  name       String
  nameEn     String?
  postcode   Json?
  communes   PosCommune[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([provinceId, name])
  @@map("pos_districts")
}

model PosCommune {
  id         String      @id
  provinceId String
  districtId String
  province   PosProvince @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  district   PosDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name       String
  nameEn     String?
  newId      String?
  postcode   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([provinceId, districtId, name])
  @@index([districtId, name])
  @@map("pos_communes")
}

enum MarketingKpiScopeType {
  TEAM
  CATEGORY
  USER
}

enum MarketingKpiCategory {
  SCALING
  TESTING
}

enum MarketingKpiMetricKey {
  TEAM_AD_SPEND
  TEAM_AR_PCT
  USER_CREATIVES_CREATED
  USER_AR_PCT
}

model MarketingKpiTarget {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @db.Uuid
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scopeType       MarketingKpiScopeType
  teamCode        String
  userId          String?               @db.Uuid
  category        MarketingKpiCategory?
  metricKey       MarketingKpiMetricKey
  targetValue     Decimal               @db.Decimal(12, 2)
  startDate       DateTime              @db.Date
  endDate         DateTime?             @db.Date
  createdByUserId String                @db.Uuid
  updatedByUserId String?               @db.Uuid
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([tenantId, scopeType, teamCode, metricKey, startDate, endDate])
  @@index([tenantId, userId, metricKey, startDate, endDate])
  @@index([tenantId, teamCode, category, metricKey, startDate, endDate])
  @@map("marketing_kpi_targets")
}

model MarketingKpiUserCategoryAssignment {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @db.Uuid
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamCode        String
  userId          String               @db.Uuid
  category        MarketingKpiCategory
  createdByUserId String               @db.Uuid
  updatedByUserId String?              @db.Uuid
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([tenantId, teamCode, userId])
  @@index([tenantId, teamCode, category])
  @@map("marketing_kpi_user_category_assignments")
}

// ============================================================================
// RECONCILED MARKETING (Ad-level reconciliation of Meta + POS)
// ============================================================================
model ReconcileMarketing {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId   String? @db.Uuid
  team     Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  date               DateTime @db.Date
  adId               String
  normalizedAdId     String?
  accountId          String?
  campaignId         String?
  campaignName       String?
  adsetId            String?
  adName             String?
  marketingAssociate String?
  mapping            String?
  teamCode           String?

  spend       Decimal @default(0) @db.Decimal(12, 2)
  clicks      Int     @default(0)
  linkClicks  Int     @default(0)
  impressions Int     @default(0)
  leads       Int     @default(0)

  dateCreated           DateTime?
  purchasesPos          Int       @default(0)
  codPos                Decimal   @default(0) @db.Decimal(12, 2)
  processedPurchasesPos Int       @default(0)
  cogsPos               Decimal   @default(0) @db.Decimal(12, 2)
  cogsCanceledPos       Decimal   @default(0) @db.Decimal(12, 2)
  cogsRestockingPos     Decimal   @default(0) @db.Decimal(12, 2)
  cogsRtsPos            Decimal   @default(0) @db.Decimal(12, 2)
  cogsDeliveredPos      Decimal   @default(0) @db.Decimal(12, 2)
  sfPos                 Decimal   @default(0) @db.Decimal(12, 2)
  ffPos                 Decimal   @default(0) @db.Decimal(12, 2)
  ifPos                 Decimal   @default(0) @db.Decimal(12, 2)
  sfSdrPos              Decimal   @default(0) @db.Decimal(12, 2)
  ffSdrPos              Decimal   @default(0) @db.Decimal(12, 2)
  ifSdrPos              Decimal   @default(0) @db.Decimal(12, 2)
  codFeePos             Decimal   @default(0) @db.Decimal(12, 2)
  codFeeDeliveredPos    Decimal   @default(0) @db.Decimal(12, 2)
  canceledCodPos        Decimal   @default(0) @db.Decimal(12, 2)
  rtsCodPos             Decimal   @default(0) @db.Decimal(12, 2)
  deliveredCodPos       Decimal   @default(0) @db.Decimal(12, 2)
  shippedCodPos         Decimal   @default(0) @db.Decimal(12, 2)
  waitingPickupCodPos   Decimal   @default(0) @db.Decimal(12, 2)
  restockingCodPos      Decimal   @default(0) @db.Decimal(12, 2)
  confirmedCodPos       Decimal   @default(0) @db.Decimal(12, 2)
  unconfirmedCodPos     Decimal   @default(0) @db.Decimal(12, 2)
  abandonedCodPos       Decimal   @default(0) @db.Decimal(12, 2)
  confirmedCount        Int       @default(0)
  unconfirmedCount      Int       @default(0)
  printedCount          Int       @default(0)
  abandonedCount        Int       @default(0)
  waitingPickupCount    Int       @default(0)
  shippedCount          Int       @default(0)
  deliveredCount        Int       @default(0)
  canceledCount         Int       @default(0)
  deletedCount          Int       @default(0)
  rtsCount              Int       @default(0)
  restockingCount       Int       @default(0)
  matchedOrders         Json      @default("[]") // optional details of matched POS orders
  shops                 Json      @default("[]") // shop ids involved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date, adId])
  @@index([tenantId, date])
  @@index([tenantId, adId, date])
  @@index([tenantId, campaignId, date])
  @@index([tenantId, teamId, date])
  @@map("reconcile_marketing")
}

// ============================================================================
// RECONCILED SALES (Campaign-level aggregation of reconcile_marketing)
// ============================================================================
model ReconcileSales {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId   String? @db.Uuid
  team     Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  date         DateTime @db.Date
  campaignId   String?
  campaignName String?
  mapping      String?
  isUnmatched  Boolean  @default(false)

  spend       Decimal @default(0) @db.Decimal(12, 2)
  clicks      Int     @default(0)
  linkClicks  Int     @default(0)
  impressions Int     @default(0)
  leads       Int     @default(0)

  purchasesPos          Int @default(0)
  processedPurchasesPos Int @default(0)
  confirmedCount        Int @default(0)
  unconfirmedCount      Int @default(0)
  printedCount          Int @default(0)
  waitingPickupCount    Int @default(0)
  shippedCount          Int @default(0)
  deliveredCount        Int @default(0)
  canceledCount         Int @default(0)
  deletedCount          Int @default(0)
  rtsCount              Int @default(0)
  restockingCount       Int @default(0)
  abandonedCount        Int @default(0)

  codPos              Decimal @default(0) @db.Decimal(12, 2)
  deliveredCodPos     Decimal @default(0) @db.Decimal(12, 2)
  shippedCodPos       Decimal @default(0) @db.Decimal(12, 2)
  waitingPickupCodPos Decimal @default(0) @db.Decimal(12, 2)
  rtsCodPos           Decimal @default(0) @db.Decimal(12, 2)
  canceledCodPos      Decimal @default(0) @db.Decimal(12, 2)
  restockingCodPos    Decimal @default(0) @db.Decimal(12, 2)
  confirmedCodPos     Decimal @default(0) @db.Decimal(12, 2)
  unconfirmedCodPos   Decimal @default(0) @db.Decimal(12, 2)
  abandonedCodPos     Decimal @default(0) @db.Decimal(12, 2)

  cogsPos           Decimal @default(0) @db.Decimal(12, 2)
  cogsCanceledPos   Decimal @default(0) @db.Decimal(12, 2)
  cogsRestockingPos Decimal @default(0) @db.Decimal(12, 2)
  cogsRtsPos        Decimal @default(0) @db.Decimal(12, 2)
  cogsDeliveredPos  Decimal @default(0) @db.Decimal(12, 2)

  sfPos              Decimal @default(0) @db.Decimal(12, 2)
  ffPos              Decimal @default(0) @db.Decimal(12, 2)
  ifPos              Decimal @default(0) @db.Decimal(12, 2)
  sfSdrPos           Decimal @default(0) @db.Decimal(12, 2)
  ffSdrPos           Decimal @default(0) @db.Decimal(12, 2)
  ifSdrPos           Decimal @default(0) @db.Decimal(12, 2)
  codFeePos          Decimal @default(0) @db.Decimal(12, 2)
  codFeeDeliveredPos Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date, campaignId])
  @@index([tenantId, teamId, date])
  @@index([tenantId, campaignId, date])
  @@index([tenantId, date, mapping])
  @@map("reconcile_sales")
}
