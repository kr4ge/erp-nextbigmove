  @@unique([tenantId, shopId, posOrderId])
  @@index([tenantId, shopId, dateLocal])
  @@index([tenantId, teamId, dateLocal])
  @@index([tenantId, status, dateLocal, confirmationUpdateRequestedAt], map: "pos_orders_confirmation_queue_idx")
  @@index([tenantId, teamId, dateLocal, isRiskConfirmation], map: "pos_orders_tenant_team_date_risk_confirmation_idx")
  @@index([tenantId, dateLocal, isVoid], map: "pos_orders_tenant_date_void_idx")
  @@index([dateLocal])
  @@index([mapping])
  @@map("pos_orders")
}

