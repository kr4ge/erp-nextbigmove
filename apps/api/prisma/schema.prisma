  updatedAt DateTime @updatedAt

  @@unique([tenantId, accountId, adId, date])
  @@index([tenantId, accountId, date])
  @@index([tenantId, teamId, date])
  @@index([date])
  @@map("meta_ad_insights")
}

// ============================================================================
// POS ORDER MODEL (Tenant-scoped)
// ============================================================================
model PosOrder {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId   String? @db.Uuid
  team     Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  shopId     String
  posOrderId String // Order ID from POS system

  // Timestamps
  insertedAt  DateTime // UTC timestamp from POS
  dateLocal   String // Manila-local date (YYYY-MM-DD)
  deliveredAt DateTime?
  rtsAt       DateTime?

  // Order details
  status                         Int?
  statusName                     String?
  cod                            Decimal?  @db.Decimal(12, 2)
  salesCod                       Decimal?  @db.Decimal(12, 2)
  mktgCod                        Decimal?  @db.Decimal(12, 2)
  isMarketingSource              Boolean   @default(false)
  forUpsell                      Boolean   @default(false)
  isRiskConfirmation             Boolean   @default(false)
  isAbandoned                    Boolean   @default(false)
  isVoid                         Boolean   @default(false)
  confirmationUpdateRequestedAt  DateTime?
  confirmationUpdateTargetStatus Int?
  reportsByPhoneOrderFail        Int?
  reportsByPhoneOrderSuccess     Int?
  reportsByPhoneWarning          Int?
  // UTM tracking
  pUtmCampaign                   String?
  pUtmContent                    String?

  // COGS calculation (from note_product)
  cogs          Decimal @default(0) @db.Decimal(12, 2)
  totalQuantity Int     @default(0)

  // Product info (from first item)
  tracking String?

  // Mapping (extracted from note_product, e.g., "Agriblast-100" → "Agriblast")
  mapping String?

  // Assignment info
  customerCare    String?
  marketer        String?
  salesAssignee   String?
  assigningCare   String?
  customerName    String?
  customerPhone   String?
  customerAddress String?
  statusHistory   Json?
  rtsReason       Json?
  upsellBreakdown Json?
  orderSnapshot   Json?
  // Order items snapshot (subset of fields)
  itemData        Json    @default("[]")
  tags            Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, shopId, posOrderId])
  @@index([tenantId, shopId, dateLocal])
  @@index([tenantId, teamId, dateLocal])
  @@index([tenantId, status, dateLocal, confirmationUpdateRequestedAt], map: "pos_orders_confirmation_queue_idx")
  @@index([tenantId, teamId, dateLocal, isRiskConfirmation], map: "pos_orders_tenant_team_date_risk_confirmation_idx")
  @@index([tenantId, dateLocal, isVoid], map: "pos_orders_tenant_date_void_idx")
  @@index([dateLocal])
  @@index([mapping])
  @@map("pos_orders")
}

