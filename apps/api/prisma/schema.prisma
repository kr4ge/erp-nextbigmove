generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================================================
// TENANT MODEL (Global - No tenantId)
// ============================================================================
model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  slug           String       @unique
  domain         String?      @unique
  status         TenantStatus @default(ACTIVE)
  companyName    String?
  billingAddress Json?
  partnerTypeId  String?      @db.Uuid

  // Settings
  settings Json     @default("{}")
  metadata Json     @default("{}")
  features String[] @default([])

  // Limits
  maxUsers        Int @default(10)
  maxIntegrations Int @default(5)

  // Encryption
  encryptionKey String // Per-tenant encryption key

  // Billing
  planType     String  @default("trial")
  billingEmail String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                               User[]
  integrations                        Integration[]
  analyticsEvents                     AnalyticsEvent[]
  pancakeWebhookLogs                  PancakeWebhookLog[]
  auditLogs                           AuditLog[]
  posStores                           PosStore[]
  metaAdAccounts                      MetaAdAccount[]
  posProductCogs                      PosProductCogs[]
  workflows                           Workflow[]
  workflowExecutions                  WorkflowExecution[]
  workflowExecutionLogs               WorkflowExecutionLog[]
  metaAdInsights                      MetaAdInsight[]
  posOrders                           PosOrder[]
  posTags                             PosTag[]
  marketingKpiTargets                 MarketingKpiTarget[]
  marketingKpiUserCategoryAssignments MarketingKpiUserCategoryAssignment[]
  reconcileMarketing                  ReconcileMarketing[]
  reconcileSales                      ReconcileSales[]
  analyticsShares                     AnalyticsShare[]
  teams                               Team[]
  teamMemberships                     TeamMembership[]
  roles                               Role[]
  userRoleAssignments                 UserRoleAssignment[]
  userPermissionAssignments           UserPermissionAssignment[]
  partnerType                         PartnerType?                         @relation(fields: [partnerTypeId], references: [id], onDelete: SetNull)
  wmsStockRequests                    WmsStockRequest[]
  wmsStockInvoices                    WmsStockRequestInvoice[]
  wmsFulfillmentOrders                WmsFulfillmentOrder[]

  @@index([slug])
  @@index([status])
  @@index([partnerTypeId])
  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

// ============================================================================
// TEAM MODEL (Tenant-scoped)
// ============================================================================
model Team {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  teamCode    String?
  description String?
  status      TeamStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members                   TeamMembership[]
  integrations              Integration[]
  workflows                 Workflow[]
  workflowExecutions        WorkflowExecution[]
  posStores                 PosStore[]
  posProductCogs            PosProductCogs[]
  metaAdAccounts            MetaAdAccount[]
  metaAdInsights            MetaAdInsight[]
  posOrders                 PosOrder[]
  posTags                   PosTag[]
  reconcileMarketing        ReconcileMarketing[]
  reconcileSales            ReconcileSales[]
  userRoleAssignments       UserRoleAssignment[]
  userPermissionAssignments UserPermissionAssignment[]
  defaultUsers              User[]                     @relation("UserDefaultTeam")
  workflowExecutionLogs     WorkflowExecutionLog[]     @relation("TeamWorkflowExecutionLog")

  // Sharing back-relations
  sharedIntegrationLinks IntegrationSharedTeam[]
  sharedWorkflowLinks    WorkflowSharedTeam[]
  analyticsSharesOwned   AnalyticsShare[]        @relation("AnalyticsShareOwner")
  analyticsSharesShared  AnalyticsShare[]        @relation("AnalyticsShareTarget")

  @@unique([tenantId, teamCode])
  @@index([tenantId])
  @@map("teams")
}

enum TeamStatus {
  ACTIVE
  ARCHIVED
}

model TeamMembership {
  id        String               @id @default(uuid()) @db.Uuid
  tenantId  String               @db.Uuid
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId    String               @db.Uuid
  team      Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String               @db.Uuid
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String?              @db.Uuid
  role      Role?                @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isDefault Boolean              @default(false)
  status    TeamMembershipStatus @default(ACTIVE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([tenantId, userId, teamId])
  @@index([tenantId])
  @@index([roleId])
  @@map("team_memberships")
}

enum TeamMembershipStatus {
  ACTIVE
  INACTIVE
}

// ============================================================================
// RBAC MODELS (dynamic roles/permissions, tenant/team scoped)
// ============================================================================
enum RoleScope {
  GLOBAL
  TENANT
  TEAM
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  name        String
  description String?
  scope       RoleScope @default(TENANT)
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]
  userAssignments UserRoleAssignment[]
  teamMemberships TeamMembership[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userAssignments UserPermissionAssignment[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenantId  String?  @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId    String?  @db.Uuid
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId, tenantId, teamId])
  @@index([tenantId])
  @@index([teamId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model UserPermissionAssignment {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  allow        Boolean    @default(true)
  tenantId     String?    @db.Uuid
  tenant       Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId       String?    @db.Uuid
  team         Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, permissionId, tenantId, teamId])
  @@index([tenantId])
  @@index([teamId])
  @@index([userId])
  @@index([permissionId])
  @@map("user_permissions")
}

// ============================================================================
// USER MODEL (Tenant-scoped)
// ============================================================================
model User {
  id         String  @id @default(uuid()) @db.Uuid
  email      String
  password   String
  firstName  String?
  lastName   String?
  avatar     String?
  employeeId String?

  // Tenant (Row-level isolation) - Optional for SUPER_ADMIN
  tenantId String? @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // RBAC (legacy enums remain for platform-level roles; dynamic roles use join tables)
  role          UserRole @default(USER)
  permissions   String[] @default([])
  defaultTeamId String?  @db.Uuid
  defaultTeam   Team?    @relation("UserDefaultTeam", fields: [defaultTeamId], references: [id], onDelete: SetNull)

  // Status
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)

  // Timestamps
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  auditLogs                 AuditLog[]
  teamMemberships           TeamMembership[]
  userRoleAssignments       UserRoleAssignment[]
  userPermissionAssignments UserPermissionAssignment[]
  wmsInventoryLedgerEntries WmsInventoryLedger[]
  wmsStockReceipts          WmsStockReceipt[]          @relation("WmsReceiptActor")
  wmsInventoryAdjustments   WmsInventoryAdjustment[]   @relation("WmsAdjustmentActor")
  wmsInventoryTransfers     WmsInventoryTransfer[]     @relation("WmsTransferActor")
  wmsPackingStations               WmsPackingStationUser[]
  wmsFulfillmentPickedOrders      WmsFulfillmentOrder[]          @relation("WmsFulfillmentPicker")
  wmsFulfillmentPackedOrders      WmsFulfillmentOrder[]          @relation("WmsFulfillmentPacker")
  wmsFulfillmentScans             WmsFulfillmentScanLog[]        @relation("WmsFulfillmentScanActor")
  wmsFulfillmentPickedAssignments WmsFulfillmentUnitAssignment[] @relation("WmsFulfillmentAssignmentPickedBy")
  wmsFulfillmentPackedAssignments WmsFulfillmentUnitAssignment[] @relation("WmsFulfillmentAssignmentPackedBy")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum WmsWarehouseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WmsLocationType {
  RECEIVING
  STORAGE
  PICKING
  PACKING
  STAGING
  RETURNS
  DAMAGE
  QUARANTINE
  DISPATCH
}

enum WmsLocationStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WmsInventoryLotStatus {
  ACTIVE
  HOLD
  DEPLETED
  CLOSED
}

enum WmsSkuStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WmsStockRequestStatus {
  DRAFT
  SUBMITTED
  WMS_REVIEWED
  PARTNER_CONFIRMED
  PARTNER_REJECTED
  UNDER_AUDIT
  FEEDBACK_REQUIRED
  AUDIT_ACCEPTED
  INVOICED
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  IN_PROCUREMENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

enum WmsStockRequestType {
  WMS_PROCUREMENT
  PARTNER_SELF_BUY
}

enum WmsStockRequestInvoiceStatus {
  UNPAID
  PAYMENT_SUBMITTED
  PAID
  CANCELED
}

enum WmsStockRequestPaymentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

enum WmsInventoryMovementType {
  RECEIPT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RESERVE
  RELEASE
  PICK
  PACK
  DISPATCH
  RTS_RECEIPT
  DAMAGE
  RESTOCK
}

enum WmsStockReceiptStatus {
  DRAFT
  POSTED
  CANCELED
}

enum WmsInventoryAdjustmentType {
  OPENING
  INCREASE
  DECREASE
  WRITE_OFF
}

enum WmsInventoryAdjustmentStatus {
  POSTED
  CANCELED
}

enum WmsInventoryTransferType {
  PUT_AWAY
  RELOCATION
}

enum WmsInventoryUnitStatus {
  AVAILABLE
  RESERVED
  PICKED
  PACKED
  DISPATCHED
  RETURNED
  DAMAGED
  ADJUSTED_OUT
}

enum WmsPackingStationStatus {
  ACTIVE
  INACTIVE
}

enum WmsFulfillmentOrderStatus {
  PENDING
  WAITING_FOR_STOCK
  PICKING
  PICKED
  PACKING_PENDING
  PACKING_ASSIGNED
  PACKING
  PACKED
  DISPATCHED
  HOLD
  CANCELED
}

enum WmsFulfillmentScanStage {
  PICKING
  PACKING
  DISPATCH
}

enum WmsFulfillmentScanResult {
  ACCEPTED
  REJECTED
}

model PartnerType {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]

  @@index([isActive, name])
  @@map("partner_types")
}

model WmsCompanyBillingSettings {
  id                String   @id @default(uuid()) @db.Uuid
  companyName       String
  billingAddress    Json
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankAccountType   String?
  notes             String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("wms_company_billing_settings")
}

model WmsWarehouse {
  id           String             @id @default(uuid()) @db.Uuid
  code         String             @unique
  name         String
  description  String?
  status       WmsWarehouseStatus @default(ACTIVE)
  isDefault    Boolean            @default(false)
  contactName  String?
  contactPhone String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  postalCode   String?
  country      String             @default("Philippines")
  notes        String?
  metadata     Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  locations              WmsLocation[]
  inventoryLots          WmsInventoryLot[]
  inventoryBalances      WmsInventoryBalance[]
  inventoryCostLayers    WmsInventoryCostLayer[]
  inventoryLedgerEntries WmsInventoryLedger[]
  inventoryUnits         WmsInventoryUnit[]
  stockReceipts          WmsStockReceipt[]
  inventoryAdjustments   WmsInventoryAdjustment[]
  inventoryTransfers     WmsInventoryTransfer[]
  packingStations        WmsPackingStation[]
  fulfillmentOrders      WmsFulfillmentOrder[]

  @@index([status])
  @@index([isDefault])
  @@map("wms_warehouses")
}

model WmsLocation {
  id            String            @id @default(uuid()) @db.Uuid
  warehouseId   String            @db.Uuid
  warehouse     WmsWarehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parentId      String?           @db.Uuid
  parent        WmsLocation?      @relation("WmsLocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      WmsLocation[]     @relation("WmsLocationHierarchy")
  code          String
  name          String
  description   String?
  type          WmsLocationType   @default(STORAGE)
  status        WmsLocationStatus @default(ACTIVE)
  isDefault     Boolean           @default(false)
  barcode       String?           @unique
  capacityUnits Int?
  sortOrder     Int               @default(0)
  metadata      Json              @default("{}")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  inventoryLots              WmsInventoryLot[]        @relation("WmsLotReceivedLocation")
  inventoryBalances          WmsInventoryBalance[]
  inventoryLedgerEntries     WmsInventoryLedger[]
  inventoryUnits             WmsInventoryUnit[]
  stockReceipts              WmsStockReceipt[]
  inventoryAdjustments       WmsInventoryAdjustment[]
  outboundInventoryTransfers WmsInventoryTransfer[]   @relation("WmsTransferFromLocation")
  inboundInventoryTransfers  WmsInventoryTransfer[]   @relation("WmsTransferToLocation")

  @@unique([warehouseId, code])
  @@index([warehouseId, status])
  @@index([warehouseId, parentId, sortOrder])
  @@index([isDefault])
  @@map("wms_locations")
}

model WmsInventoryLot {
  id                 String                @id @default(uuid()) @db.Uuid
  lotCode            String                @unique
  warehouseId        String                @db.Uuid
  warehouse          WmsWarehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  receivedLocationId String?               @db.Uuid
  receivedLocation   WmsLocation?          @relation("WmsLotReceivedLocation", fields: [receivedLocationId], references: [id], onDelete: SetNull)
  sku                String
  productName        String
  variationId        String?
  variationName      String?
  barcode            String?
  supplierBatchNo    String?
  status             WmsInventoryLotStatus @default(ACTIVE)
  receivedAt         DateTime              @default(now())
  expiresAt          DateTime?
  initialQuantity    Decimal               @db.Decimal(14, 4)
  remainingQuantity  Decimal               @db.Decimal(14, 4)
  unitCost           Decimal               @db.Decimal(14, 2)
  currency           String                @default("PHP")
  metadata           Json                  @default("{}")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  costLayers      WmsInventoryCostLayer[]
  ledgerEntries   WmsInventoryLedger[]
  receiptItems    WmsStockReceiptItem[]
  adjustmentItems WmsInventoryAdjustmentItem[]
  inventoryUnits  WmsInventoryUnit[]

  @@index([warehouseId, status, receivedAt])
  @@index([warehouseId, sku])
  @@index([barcode])
  @@index([variationId])
  @@map("wms_inventory_lots")
}

model WmsSkuProfile {
  id              String       @id @default(uuid()) @db.Uuid
  posProductId    String       @unique @db.Uuid
  posProduct      PosProduct   @relation(fields: [posProductId], references: [id], onDelete: Cascade)
  code            String?      @unique
  category        String?
  unit            String?
  packSize        String?
  barcode         String?      @unique
  description     String?
  status          WmsSkuStatus @default(ACTIVE)
  isSerialized    Boolean      @default(true)
  isLotTracked    Boolean      @default(false)
  isExpiryTracked Boolean      @default(false)
  supplierCost    Decimal?     @db.Decimal(14, 2)
  wmsUnitPrice    Decimal?     @db.Decimal(14, 2)
  isRequestable   Boolean      @default(false)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  inventoryUnits WmsInventoryUnit[]
  requestLines   WmsStockRequestLine[]

  @@index([status])
  @@index([category])
  @@index([isRequestable, status])
  @@map("wms_sku_profiles")
}

model WmsInventoryCostLayer {
  id                String          @id @default(uuid()) @db.Uuid
  warehouseId       String          @db.Uuid
  warehouse         WmsWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  lotId             String          @db.Uuid
  lot               WmsInventoryLot @relation(fields: [lotId], references: [id], onDelete: Restrict)
  sku               String
  originalQuantity  Decimal         @db.Decimal(14, 4)
  remainingQuantity Decimal         @db.Decimal(14, 4)
  unitCost          Decimal         @db.Decimal(14, 2)
  totalCost         Decimal         @db.Decimal(14, 2)
  currency          String          @default("PHP")
  receivedAt        DateTime        @default(now())
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  ledgerEntries WmsInventoryLedger[]
  receiptItems  WmsStockReceiptItem[]

  @@index([warehouseId, sku, receivedAt])
  @@index([lotId])
  @@map("wms_inventory_cost_layers")
}

model WmsInventoryBalance {
  id                String       @id @default(uuid()) @db.Uuid
  warehouseId       String       @db.Uuid
  warehouse         WmsWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  locationId        String       @db.Uuid
  location          WmsLocation  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sku               String
  productName       String
  variationId       String?
  variationName     String?
  barcode           String?
  onHandQuantity    Decimal      @default(0) @db.Decimal(14, 4)
  reservedQuantity  Decimal      @default(0) @db.Decimal(14, 4)
  availableQuantity Decimal      @default(0) @db.Decimal(14, 4)
  latestUnitCost    Decimal?     @db.Decimal(14, 2)
  inventoryValue    Decimal?     @db.Decimal(14, 2)
  metadata          Json         @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([warehouseId, locationId, sku])
  @@index([warehouseId, sku])
  @@index([locationId, sku])
  @@index([variationId])
  @@index([barcode])
  @@map("wms_inventory_balances")
}

model WmsInventoryTransfer {
  id             String                   @id @default(uuid()) @db.Uuid
  transferCode   String                   @unique
  warehouseId    String                   @db.Uuid
  warehouse      WmsWarehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  fromLocationId String                   @db.Uuid
  fromLocation   WmsLocation              @relation("WmsTransferFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocationId   String                   @db.Uuid
  toLocation     WmsLocation              @relation("WmsTransferToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  actorUserId    String?                  @db.Uuid
  actorUser      User?                    @relation("WmsTransferActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  transferType   WmsInventoryTransferType
  notes          String?
  happenedAt     DateTime                 @default(now())
  totalUnits     Int                      @default(0)
  metadata       Json                     @default("{}")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  items WmsInventoryTransferItem[]

  @@index([warehouseId, happenedAt])
  @@index([fromLocationId, happenedAt])
  @@index([toLocationId, happenedAt])
  @@index([actorUserId, happenedAt])
  @@index([transferType, happenedAt])
  @@map("wms_inventory_transfers")
}

model WmsInventoryUnit {
  id                     String                      @id @default(uuid()) @db.Uuid
  serialNo               BigInt                      @unique @default(autoincrement()) @db.BigInt
  batchSequence          Int
  unitBarcode            String                      @unique
  warehouseId            String                      @db.Uuid
  warehouse              WmsWarehouse                @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  locationId             String                      @db.Uuid
  location               WmsLocation                 @relation(fields: [locationId], references: [id], onDelete: Restrict)
  lotId                  String                      @db.Uuid
  lot                    WmsInventoryLot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  skuProfileId           String?                     @db.Uuid
  skuProfile             WmsSkuProfile?              @relation(fields: [skuProfileId], references: [id], onDelete: SetNull)
  receiptItemId          String?                     @db.Uuid
  receiptItem            WmsStockReceiptItem?        @relation(fields: [receiptItemId], references: [id], onDelete: SetNull)
  sourceAdjustmentItemId String?                     @db.Uuid
  sourceAdjustmentItem   WmsInventoryAdjustmentItem? @relation("WmsUnitSourceAdjustmentItem", fields: [sourceAdjustmentItemId], references: [id], onDelete: SetNull)
  sku                    String
  productName            String
  variationId            String?
  variationName          String?
  barcode                String?
  status                 WmsInventoryUnitStatus      @default(AVAILABLE)
  lastMovementType       WmsInventoryMovementType    @default(RECEIPT)
  lastReferenceType      String?                     @db.VarChar(64)
  lastReferenceId        String?                     @db.VarChar(64)
  receivedAt             DateTime                    @default(now())
  consumedAt             DateTime?
  metadata               Json                        @default("{}")
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  transferItems WmsInventoryTransferItem[]
  fulfillmentAssignments WmsFulfillmentUnitAssignment[]
  fulfillmentScanLogs WmsFulfillmentScanLog[]

  @@unique([lotId, batchSequence])
  @@index([warehouseId, status, receivedAt])
  @@index([locationId, status, receivedAt])
  @@index([lotId, status])
  @@index([skuProfileId, status])
  @@index([sku, status])
  @@index([variationId, status])
  @@index([lastReferenceType, lastReferenceId])
  @@map("wms_inventory_units")
}

model WmsInventoryTransferItem {
  id            String               @id @default(uuid()) @db.Uuid
  transferId    String               @db.Uuid
  transfer      WmsInventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
