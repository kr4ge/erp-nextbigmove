# Application
NODE_ENV=development
PORT=3001
TZ=Asia/Manila

# Database
DATABASE_URL="postgresql://erp_user:dev_password@localhost:5433/erp_analytics?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-in-production-use-strong-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-chars-change-in-production-use-strong-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# CORS Origins
CORS_ORIGIN_WEB=http://localhost:3000
CORS_ORIGIN_ADMIN=http://localhost:3002

# Next.js Web App
NEXT_PUBLIC_TIMEZONE=Asia/Manila
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Next.js Admin App
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001/api/v1

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Encryption (per-tenant keys stored in DB)
MASTER_ENCRYPTION_KEY=your-master-encryption-key-32-bytes-hex-change-in-production

# Workflows
# Set to true to process workflow executions inline (useful if Redis/Bull queue is unavailable in development)
WORKFLOW_PROCESS_INLINE=true

# Object Storage (S3-compatible: MinIO locally, Spaces/S3 in production)
OBJECT_STORAGE_PROVIDER=s3-compatible
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=erp-local-media
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=900
OBJECT_STORAGE_PAYMENT_PROOF_MAX_FILE_MB=8
OBJECT_STORAGE_STOX_APK_MAX_FILE_MB=150

# Queue tuning
CONFIRMATION_UPDATE_QUEUE_CONCURRENCY=4
WMS_PICKING_HANDOFF_QUEUE_CONCURRENCY=4
WMS_PICKING_HANDOFF_QUEUE_ATTEMPTS=4
WMS_PICKING_HANDOFF_QUEUE_BACKOFF_MS=3000
WMS_PICKING_HANDOFF_QUEUE_TIMEOUT_MS=45000

# WMS feature rollout
WMS_BASKET_DEMAND_PICKING_ENABLED=true
WMS_STOX_LEGACY_RESERVED_ENABLED=false
